{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://registack.eu/schemas/agrp-deployment-conformance.v0.3.json",
  "title": "AGRP Deployment Conformance Statement v0.3",
  "type": "object",
  "required": [
    "agrp_version",
    "conformance_level",
    "supported_codes",
    "issuer"
  ],
  "properties": {
    "agrp_version": {
      "type": "string",
      "const": "0.3"
    },
    "conformance_level": {
      "type": "string",
      "enum": ["A", "B", "C", "D"]
    },
    "supported_codes": {
      "type": "array",
      "items": {
        "type": "integer",
        "enum": [601, 602, 603, 604, 605, 606, 607, 608, 609, 610, 611, 612, 613, 614, 615]
      },
      "uniqueItems": true,
      "minItems": 15
    },
    "signed_profile": {
      "type": "string"
    },
    "extension_namespaces": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(?:[A-Za-z0-9-]+\\.)+[A-Za-z0-9-]+$|^https://.+$"
      },
      "uniqueItems": true
    },
    "issuer": {
      "type": "string"
    },
    "policy_references": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "conformance_level": { "const": "C" } }, "required": ["conformance_level"] },
      "then": { "required": ["signed_profile"] }
    },
    {
      "if": { "properties": { "conformance_level": { "const": "D" } }, "required": ["conformance_level"] },
      "then": { "required": ["signed_profile", "extension_namespaces"] }
    }
  ],
  "additionalProperties": false
}
